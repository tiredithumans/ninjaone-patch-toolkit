{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_response.filePath // .tool_input.file_path' 2>/dev/null); [ -n \"$f\" ] && [ \"$f\" != \"null\" ] && case \"$f\" in *.rs) rustfmt --edition 2024 \"$f\" ;; esac 2>/dev/null || true"
          },
          {
            "type": "command",
            "timeout": 5,
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agents-md-staleness-check.sh"
          },
          {
            "type": "command",
            "timeout": 5,
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/docs-staleness-check.sh"
          },
          {
            "type": "command",
            "timeout": 10,
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/command-parity-check.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/conventional-commit-validator.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 30,
            "command": "SCAN_MODE=warn SCAN_SCOPE=diff \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/secrets-scanner.sh"
          }
        ]
      }
    ]
  }
}
